{
  "name": "holyrics-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @holyrics-control/web --filter @holyrics-control/server dev",
    "dev:web": "pnpm --filter @holyrics-control/web dev",
    "dev:server": "pnpm --filter @holyrics-control/server dev",
    "build": "pnpm --filter @holyrics-control/shared build && pnpm --filter @holyrics-control/web build && pnpm --filter @holyrics-control/server build",
    "start": "pnpm --filter @holyrics-control/server start",
    "lint": "eslint .",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.14.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  },
  "packageManager": "pnpm@10.9.0"
}
